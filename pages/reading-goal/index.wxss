.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.progress-block {
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eef0f3;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 18rpx;
}

.metric-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 24rpx;
  color: #4b5563;
  margin: 12rpx 0;
}

.progress-track {
  height: 12rpx;
  border-radius: 6rpx;
  background: #eef0f3;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: #07c160;
}

.progress-fill.day {
  background: #ff9f4a;
}

.label {
  margin-top: 16rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

.btn {
  margin-top: 28rpx;
  background: #07c160;
  color: #fff;
}
