.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.label {
  margin-top: 12rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.input {
  border: 1rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 26rpx;
}

.btn {
  margin-top: 28rpx;
  background: #07c160;
  color: #fff;
}
