.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.subtitle {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.section-title {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.paragraph {
  font-size: 24rpx;
  line-height: 1.8;
  color: #4b5563;
}

.section {
  padding: 8rpx 0;
}

.contact-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.copy-btn {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #e0e7ff;
  color: #3730a3;
  font-size: 22rpx;
}

.updated {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #9ca3af;
}
