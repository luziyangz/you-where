.page-container {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding-bottom: 40rpx;
}

.container {
  padding: 30rpx;
}

/* 空状态内容 */
.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.illustration-box {
  width: 320rpx;
  height: 320rpx;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.05), rgba(255, 159, 74, 0.05));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.icon-user-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: rgba(7, 193, 96, 0.1);
  mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>') no-repeat center;
  -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>') no-repeat center;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

.auth-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-secondary {
  background: #ffffff;
  color: #07c160;
  border: 2rpx solid rgba(7, 193, 96, 0.35);
}

.btn-secondary::after {
  border: none;
}

/* 个人信息卡 */
.user-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.avatar-box {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: #FFFFFF;
}

.profile-avatar {
  width: 100%;
  height: 100%;
}

.avatar-text-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  color: #07C160;
  font-size: 48rpx;
  font-weight: bold;
}

.user-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.nickname-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.nickname-edit-icon {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(7, 193, 96, 0.35);
  background: rgba(7, 193, 96, 0.08);
  color: #07C160;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

.join-days {
  font-size: 24rpx;
  color: #CCCCCC;
}

.join-code-row {
  margin-top: 10rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.join-code-label {
  font-size: 22rpx;
  color: #999999;
}

.join-code-value {
  font-size: 24rpx;
  color: #333333;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.join-code-copy {
  font-size: 20rpx;
  color: #07C160;
}

.nickname-editor-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.nickname-editor {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-sizing: border-box;
}

.nickname-editor-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}

.nickname-editor-input {
  height: 84rpx;
  border: 1rpx solid #E5E7EB;
  border-radius: 16rpx;
  padding: 0 22rpx;
  font-size: 28rpx;
  color: #222;
}

.nickname-editor-actions {
  margin-top: 22rpx;
  display: flex;
  gap: 18rpx;
}

.nickname-editor-cancel,
.nickname-editor-save {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.nickname-editor-cancel {
  background: #F3F4F6;
  color: #4B5563;
}

.nickname-editor-save {
  background: #07C160;
  color: #fff;
}

/* 成就数据 */
.stats-section {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  padding: 0 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.num {
  font-size: 48rpx;
  font-weight: 900;
  color: #333333;
}

.unit {
  font-size: 24rpx;
  color: #CCCCCC;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.goal-card {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.goal-title {
  font-size: 30rpx;
  color: #1A1A1A;
  font-weight: 700;
}

.goal-link {
  font-size: 24rpx;
  color: #07C160;
  padding: 8rpx 0 8rpx 24rpx;
}

.goal-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #666666;
  font-size: 24rpx;
  margin-bottom: 14rpx;
}

.goal-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: #F1F3F5;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.goal-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #07C160, #45D483);
}

.goal-fill.day {
  background: linear-gradient(90deg, #FF9F4A, #FFD166);
}

/* 设置列表 */
.settings-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.setting-item {
  padding: 30rpx 40rpx;
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #F9F9F9;
}

.setting-item.no-border {
  border-bottom: none;
}

.setting-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bg-green { background: #E8F5E9; }
.bg-yellow { background: #FFF9C4; }
.bg-blue { background: #E3F2FD; }
.bg-gray { background: #F5F5F5; }

