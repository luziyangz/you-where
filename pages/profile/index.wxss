.setting-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.arrow-right {
  width: 24rpx;
  height: 24rpx;
  background: #CCCCCC;
  mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>') no-repeat center;
  -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>') no-repeat center;
}

/* 退出登录按钮 */
.logout-btn {
  background: #FFFFFF;
  border-radius: 32rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FF4D4F;
  font-weight: 500;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

/* 伙伴卡片 (如果有) */
.partner-badge-card {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx solid #C8E6C9;
  border-radius: 40rpx;
  padding: 30rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.partner-info {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.partner-avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  box-sizing: border-box;
}

.avatar-text-fallback-small {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 159, 74, 0.1);
  color: var(--partner);
  font-size: 32rpx;
  font-weight: bold;
}

.partner-detail {
  display: flex;
  flex-direction: column;
}

.partner-label {
  font-size: 20rpx;
  color: #999999;
  margin-bottom: 4rpx;
}

.partner-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333333;
}

.status-tag-mini {
  background: rgba(7, 193, 96, 0.1);
  color: var(--me);
  font-size: 20rpx;
  font-weight: bold;
  padding: 6rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
}
