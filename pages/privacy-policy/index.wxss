.page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.updated {
  margin-top: 8rpx;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.section-title {
  margin-top: 20rpx;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.paragraph {
  font-size: 24rpx;
  line-height: 1.8;
  color: #4b5563;
}

.toc {
  margin-bottom: 18rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 16rpx;
  padding: 16rpx;
  background: #f9fafb;
}

.toc-title {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.toc-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.toc-item {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1f2937;
  background: #eef2ff;
}

.section {
  padding: 10rpx 0;
}
