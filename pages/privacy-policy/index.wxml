<view class="page">
  <view class="card">
    <view class="title">隐私政策</view>
    <view class="updated">更新日期：{{meta.updatedAt}}</view>

    <view class="toc">
      <view class="toc-title">目录</view>
      <view class="toc-list">
        <view
          wx:for="{{sections}}"
          wx:key="id"
          class="toc-item"
          data-id="{{item.id}}"
          bindtap="onJumpSection"
        >
          {{item.title}}
        </view>
      </view>
    </view>

    <view
      wx:for="{{sections}}"
      wx:key="id"
      id="section-{{item.id}}"
      class="section"
      data-id="{{item.id}}"
      bindtap="onToggleSection"
    >
      <view class="section-title">{{item.title}}</view>
      <view class="paragraph" wx:if="{{expandedIds.indexOf(item.id) !== -1}}">{{item.content}}</view>
    </view>
  </view>
</view>
