.page-container {
  min-height: 100vh;
  background-color: #F8F9FC;
  padding-bottom: 200rpx;
}

.flex { display: flex; }
.items-center { align-items: center; }
.gap-2 { gap: 16rpx; }
.w-full { width: 100%; }

/* 顶部导航 */
.glass-nav {
  background: rgba(248, 249, 252, 0.9);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
  border-bottom: 1rpx solid #F1F1F1;
}

.nav-indicator {
  width: 8rpx;
  height: 32rpx;
  background: var(--me);
  border-radius: 999rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
}

/* 空状态内容 */
.empty-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.illustration-box {
  width: 320rpx;
  height: 320rpx;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.05), rgba(255, 159, 74, 0.05));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.icon-book-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: rgba(7, 193, 96, 0.1);
  mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>') no-repeat center;
  -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>') no-repeat center;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 60rpx;
  line-height: 1.6;
}

/* 书籍进度卡片 */
.book-progress-card {
  padding: 40rpx;
}

.finish-status-box {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.finish-chip {
  font-size: 22rpx;
  color: #8C8C8C;
  background: #F5F5F5;
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
}

.finish-chip.done {
  color: #07C160;
  background: #E8F8EE;
}

.finish-tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #B45309;
}

.finish-tip.success {
  color: #07C160;
}

.book-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.status-tag {
  font-size: 20rpx;
  color: var(--partner);
  font-weight: bold;
  margin-bottom: 8rpx;
}

.book-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.book-author {
  font-size: 24rpx;
  color: #999999;
}

.book-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 22rpx;
  gap: 8rpx;
}

.reading-days { color: var(--me); font-weight: bold; }
.total-pages { color: #CCCCCC; }

/* 进度条区域 */
.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333333;
}

.progress-diff {
  font-size: 22rpx;
  color: #999999;
}

.progress-marker {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 10;
}

.marker-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid #FFFFFF;
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
  margin-bottom: 8rpx;
}

.marker-avatar image {
  width: 100%;
  height: 100%;
}

.me-border { border-color: var(--me); }
.partner-border { border-color: var(--partner); }

.marker-label {
  font-size: 20rpx;
  font-weight: bold;
  white-space: nowrap;
}

.me-text { color: var(--me); }
.partner-text { color: var(--partner); }

/* 共读笔记流 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.locate-btn {
  font-size: 20rpx;
  color: #FFFFFF;
  background: #07C160;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A1A1A;
}

.count-tag {
  font-size: 24rpx;
  color: #CCCCCC;
}

.unread-badge {
  background: #FF4D4F;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
}

.notes-stream {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  max-height: calc(100vh - 620rpx);
}

.note-card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.note-me { border-radius: 40rpx 0 40rpx 40rpx; background: rgba(7, 193, 96, 0.03); }
.note-partner { border-radius: 0 40rpx 40rpx 40rpx; background: rgba(255, 159, 74, 0.03); }

.note-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.note-user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.note-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
}

.note-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.note-username {
  font-size: 22rpx;
  color: #999999;
}

.note-page {
  font-size: 20rpx;
  font-weight: bold;
}

.note-time {
  font-size: 20rpx;
  color: #CCCCCC;
}

.note-content-box {
  padding: 10rpx 0;
}

.note-text {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
}

.note-locked {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: #F5F7F9;
  border-radius: 24rpx;
}

.lock-icon-box {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 0, 0, 0.05);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.icon-lock {
  width: 32rpx;
  height: 32rpx;
  background: #CCCCCC;
  mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>') no-repeat center;
  -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>') no-repeat center;
}

.lock-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #999999;
  margin-bottom: 8rpx;
}

.lock-hint {
  font-size: 20rpx;
  color: #CCCCCC;
  text-align: center;
}

.note-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.02);
}

.reply-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: var(--me);
  font-weight: bold;
}

.replies-list {
  margin-top: 16rpx;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
}

.reply-item {
  font-size: 22rpx;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.reply-item:last-child { margin-bottom: 0; }

.reply-user { font-weight: bold; color: #666666; }
.reply-content { color: #333333; }

.load-more-wrap {
  padding: 12rpx 0 20rpx;
  display: flex;
  justify-content: center;
}

.btn-load-more {
  width: 240rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #07C160;
  background: #EBFAF1;
}

/* 底部操作栏 */
.bottom-action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20px);
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  z-index: 40;
  border-top: 1rpx solid #F1F1F1;
}

.action-btn {
  width: 100%;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

/* 弹窗表单 */
.composer-form {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.page-input-box {
  background: #F9F9F9;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
}

.input-row {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
}

.page-input {
  font-size: 60rpx;
  font-weight: bold;
  color: var(--me);
  width: 160rpx;
}

.total-pages-label {
  font-size: 28rpx;
  color: #CCCCCC;
  font-weight: bold;
}

.note-textarea {
  width: 100%;
  height: 240rpx;
  background: #F9F9F9;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.reply-textarea {
  width: 100%;
  height: 320rpx;
  background: #F9F9F9;
  border-radius: 32rpx;
  padding: 30rpx 40rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 40rpx;
}

.finish-checkbox {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: #666666;
  padding: 10rpx;
}

.checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #DDDDDD;
  border-radius: 10rpx;
}

.finish-checkbox.checked .checkbox-icon {
  background: var(--me);
  border-color: var(--me);
}

.lock-warning {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #FFFBE6;
  border: 1rpx solid #FFE58F;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
}

.lock-warning text {
  font-size: 22rpx;
  color: #D48806;
}
