.container {
  min-height: 100vh;
  background-color: #f7f7f7;
  padding-bottom: 40rpx;
}

/* 搜索栏 */
.search-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-input-box {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 30rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 16rpx;
  color: #333;
}

/* 分类导航 */
.category-scroll {
  width: 100%;
  background-color: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #eee;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.category-item.active {
  color: #07c160;
  font-weight: bold;
}

.category-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #07c160;
  border-radius: 4rpx;
}

/* 书籍列表 */
.book-list {
  padding: 20rpx 30rpx;
}

.book-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.book-cover {
  width: 160rpx;
  height: 224rpx;
  border-radius: 8rpx;
  background-color: #eee;
  flex-shrink: 0;
}

.book-info {
  margin-left: 24rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-info.no-cover {
  margin-left: 0;
}

.book-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.category-badge {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #E8F5E9;
  color: #047857;
  font-size: 22rpx;
  font-weight: 600;
}

.book-status {
  color: #9CA3AF;
  font-size: 22rpx;
}

.book-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.book-author {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.book-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

.book-review {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.book-review-tag {
  display: inline-block;
  margin-right: 8rpx;
  padding: 2rpx 10rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #047857;
  background: #d1fae5;
}

.loading-more {
  padding: 20rpx 0 40rpx;
  text-align: center;
  color: #9CA3AF;
  font-size: 24rpx;
}
