/**
 * 全局样式文件 - 适配 ui_final.html 设计风格
 * 颜色规范：
 * --me: #07C160 (本人/绿色)
 * --partner: #FF9F4A (伙伴/橙色)
 * --lock: #E9ECF0 (锁定/灰色)
 * --bg: #F8F9FC (背景色)
 */

page {
  background-color: #F7F8FA;
  color: #333333;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei',
    sans-serif;
  --me: #07C160;
  --partner: #FF9F4A;
  --lock: #E9ECF0;
  --bg: #F7F8FA;
}

/* 通用容器样式 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 顶部导航栏样式适配 */
.glass-nav {
  background: rgba(248, 249, 252, 0.9);
  backdrop-filter: blur(10px);
  position: sticky;
  top: 0;
  z-index: 50;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
  border-bottom: 1rpx solid #F1F1F1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
}

/* 卡片基础样式 */
.card {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

/* 按钮样式 */
.btn-primary {
  background: var(--me);
  color: #FFFFFF;
  border-radius: 32rpx;
  font-weight: bold;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(7, 193, 96, 0.2);
}

.btn-secondary {
  background: rgba(7, 193, 96, 0.1);
  color: var(--me);
  border-radius: 32rpx;
  font-weight: bold;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 进度条通用样式 */
.progress-track {
  position: relative;
  height: 16rpx;
  background: #E5E7EB;
  border-radius: 8rpx;
  margin: 40rpx 0;
}

.progress-bar-me {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: var(--me);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-bar-partner {
  position: absolute;
  top: 0;
  left: 0;
  height: 100%;
  background: var(--partner);
  border-radius: 8rpx;
  opacity: 0.5;
  transition: width 0.3s ease;
}

/* 弹窗遮罩层 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(4px);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  background: #FFFFFF;
  width: 640rpx;
  border-radius: 64rpx;
  overflow: hidden;
  position: relative;
}

.modal-header-line {
  height: 8rpx;
  width: 100%;
  background: linear-gradient(to right, var(--me), #A7F3D0);
}

.modal-padding {
  padding: 60rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.close-icon {
  font-size: 40rpx;
  color: #CCC;
  line-height: 1;
  padding: 10rpx;
}

/* 辅助类 */
.w-full { width: 100% !important; box-sizing: border-box; }
.flex { display: flex; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-2 { gap: 16rpx; }
.gap-3 { gap: 24rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-4 { margin-bottom: 32rpx; }
.mb-6 { margin-bottom: 48rpx; }
.mt-8 { margin-top: 64rpx; }
.text-center { text-align: center; }
